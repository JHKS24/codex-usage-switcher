    use.add_argument("--apply", action="store_true")
    use.add_argument("--json", action="store_true")
    use.set_defaults(func=command_use)
    save = sub.add_parser("save")
    save.add_argument("profile")
    save.add_argument("--apply", action="store_true")
    save.add_argument("--force", action="store_true")
    save.add_argument("--json", action="store_true")
    save.set_defaults(func=command_save)
    restore = sub.add_parser("restore")
    restore.add_argument("backup_id")
    restore.add_argument("--apply", action="store_true")
    restore.set_defaults(func=command_restore)
    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except SystemExit:
        raise
    except KeyboardInterrupt:
        raise SystemExit(130)
    except Exception as error:
        # Last-resort boundary: callers get a structured error and a stable
        # exit code instead of a traceback on stdout's sibling stream.
        if getattr(args, "json", False):
            emit_json({"ok": False, "error": f"unexpected failure: {error}", "exit_code": EXIT_OTHER})
            raise SystemExit(EXIT_OTHER)
        die(f"unexpected failure: {error}", EXIT_OTHER)


if __name__ == "__main__":
    main()
