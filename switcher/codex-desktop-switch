    print(f"cleared_cooldown\t{'yes' if cooldown_existed else 'no'}")
    print("credential_untouched\tyes")


def classify_claude_failure(detail: str) -> str:
    """Transient network failures must not be reported as login problems."""
    lowered = detail.lower()
    # No bare "expired" match: a TLS "certificate has expired" error is a
    # network problem, not a login problem.
    if "http 401" in lowered or "http 403" in lowered or "invalid_grant" in lowered or "token expired" in lowered:
        return "login_required"
    if "http 429" in lowered or "rate limit" in lowered or "rate_limit" in lowered:
        return "rate_limited"
    return "network"


def claude_usage_payload() -> dict:
    fetched_at = datetime.now(timezone.utc).isoformat()
    try:
        credentials = claude_valid_credentials()
    except RuntimeError as error:
        return {
            "ok": False,
            "source": "anthropic_oauth_usage",
            "authenticated": False,
            "error": classify_claude_failure(str(error)),
            "message": str(error),
            "fetched_at": fetched_at,
        }
    if not credentials:
        cooldown_remaining = claude_cooldown_remaining()
        if cooldown_remaining > 0:
            return {
                "ok": True,
                "source": "anthropic_oauth_usage",
                "authenticated": False,
                "error": "rate_limited",
                "retry_after_seconds": cooldown_remaining,
                "fetched_at": fetched_at,
            }
        return {"ok": True, "source": "anthropic_oauth_usage", "authenticated": False, "error": "login_required", "fetched_at": fetched_at}
    try:
        raw_usage = claude_get_authorized(CLAUDE_USAGE_ENDPOINT, credentials["access_token"])
    except RuntimeError as error:
        return {
            "ok": False,
            "source": "anthropic_oauth_usage",
            "authenticated": True,
            "error": classify_claude_failure(str(error)),
            "message": str(error),
            "fetched_at": fetched_at,
        }
    return {
        "ok": True,
        "source": "anthropic_oauth_usage",
        "credential_source": credentials.get("credential_source", "unknown"),
        "authenticated": True,
        "five_hour": claude_bucket(raw_usage, "five_hour"),
        "seven_day": claude_bucket(raw_usage, "seven_day"),
        "fetched_at": fetched_at,
    }


def command_claude_usage(args: argparse.Namespace) -> None:
    payload = claude_usage_payload()
    if getattr(args, "json", False):
        emit_json(payload)
        if not payload.get("ok"):
            raise SystemExit(EXIT_CLAUDE_USAGE)
        return
    if not payload.get("ok"):
        die(payload.get("message") or "Claude usage request failed", EXIT_CLAUDE_USAGE)
    if not payload.get("authenticated"):
        print("authenticated\tno")
        print("next\trun codex-desktop-switch claude-login")
        return
    print("source\tanthropic_oauth_usage")
    print("authenticated\tyes")
    for label, key in (("5H", "five_hour"), ("Week", "seven_day")):
        bucket = payload.get(key) or {}
        util = bucket.get("utilization")
        print(f"{label}\t{util if util is not None else '-'}%")


def command_snapshot(_args: argparse.Namespace) -> None:
    """Everything the tray apps need, in one interpreter boot.

    The three slow sources (process table, per-profile usage HTTP, Claude
    usage HTTP) run concurrently so worst-case wall time stays under the
    frontends' kill budget.
    """
    pool = ThreadPoolExecutor(max_workers=3)
    try:
        current_future = pool.submit(current_state_payload)
        usage_future = pool.submit(collect_usage_rows, profile_dirs())
        claude_future = pool.submit(claude_usage_payload)
        try:
            current = current_future.result(timeout=25)
        except Exception:
            current = {"ok": False, "active_label": "unknown", "matched_profile": None, "auth_match": "unknown", "codex_running": None}
        try:
            usage = usage_future.result(timeout=CODEX_USAGE_TOTAL_BUDGET_SECONDS + 5)
        except Exception:
            usage = []
        try:
            claude = claude_future.result(timeout=30)
        except Exception:
            claude = {"ok": False, "source": "anthropic_oauth_usage", "authenticated": False, "error": "network", "fetched_at": datetime.now(timezone.utc).isoformat()}
    finally:
        pool.shutdown(wait=False, cancel_futures=True)
    emit_json({
        "ok": True,
        "profiles_root": str(PROFILES_ROOT),
        "profiles": profile_summaries(),
        "current": current,
        "usage": usage,
        "claude_usage": claude,
        "fetched_at": datetime.now(timezone.utc).isoformat(),
    })
    # Exit without joining lingering worker threads (Python's atexit would wait
    # for them); a stalled HTTP fetch must not hold the emitted JSON hostage
    # past the frontends' kill budget.
    sys.stdout.flush()
    sys.stderr.flush()
    os._exit(EXIT_OK)


def command_login(args: argparse.Namespace) -> None:
    profile = validate_profile_name(args.profile)
    profile_home = PROFILES_ROOT / profile
    profile_home.mkdir(mode=0o700, parents=True, exist_ok=True)
    codex_cli = resolve_codex_cli_path()
    if not codex_cli or not codex_cli.exists():
        die("Codex CLI not found. Put `codex` in PATH or set CODEX_CLI_PATH.", EXIT_MISSING)
    print(f"profile\t{profile}")
    print(f"codex_home\t{profile_home}")
    print("action\topen Codex browser login for this profile")
    env = os.environ.copy()
    env["CODEX_HOME"] = str(profile_home)
    result = subprocess.run([str(codex_cli), "login"], check=False, env=env)
    if result.returncode:
        die(f"codex login failed for profile: {profile}", result.returncode)


