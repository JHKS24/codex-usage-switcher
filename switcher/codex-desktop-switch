    failure_code = EXIT_PROCESS_UNKNOWN if payload.get("process_check") == "unknown" else EXIT_CODEX_RUNNING
    if getattr(args, "json", False):
        emit_json(payload)
        raise SystemExit(EXIT_OK if payload.get("ok") else failure_code)
