def windows_powershell_executable() -> str:
    return shutil.which("pwsh") or shutil.which("powershell") or "powershell"


def concise_process_text(pid: int, name: str, command: str) -> str:
    command = command or name
    return f"{pid} {command}"[:220]


def validate_profile_name(name: str) -> str:
    if not PROFILE_RE.match(name):
        die("invalid profile name; use letters, numbers, underscore, dash, or dot only")
    return name


def profile_auth_path(name: str) -> Path:
    validate_profile_name(name)
    return PROFILES_ROOT / name / AUTH_NAME


def target_auth_path() -> Path:
    return CODEX_HOME / AUTH_NAME


def file_summary(path: Path) -> str:
    try:
        st = path.stat()
    except OSError:
        return "missing"
    mode = stat.S_IMODE(st.st_mode)
    return f"exists size={st.st_size} mode={mode:o}"


def file_summary_obj(path: Path) -> dict:
    try:
        st = path.stat()
    except OSError:
        return {"path": str(path), "exists": False}
    mode = stat.S_IMODE(st.st_mode)
    return {
        "path": str(path),
        "exists": True,
        "size": st.st_size,
        "mode": f"{mode:o}",
        "mtime": int(st.st_mtime),
    }


def sha256_file(path: Path) -> str | None:
    digest = hashlib.sha256()
    try:
        with path.open("rb") as handle:
            for chunk in iter(lambda: handle.read(1024 * 1024), b""):
                digest.update(chunk)
    except OSError:
        # Codex Desktop rewrites auth.json concurrently; a race here must
        # degrade to "no hash", not crash the status command.
        return None
    return digest.hexdigest()


def profile_dirs() -> list[Path]:
    if not PROFILES_ROOT.exists():
        return []
    return sorted(p for p in PROFILES_ROOT.iterdir() if p.is_dir())


def profile_summaries() -> list[dict]:
    summaries: list[dict] = []
    for profile_dir in profile_dirs():
        auth = profile_dir / AUTH_NAME
        item = {"profile": profile_dir.name}
        item.update(file_summary_obj(auth))
        summaries.append(item)
    return summaries


def active_label() -> str:
    return ACTIVE_FILE.read_text(encoding="utf-8").strip() if ACTIVE_FILE.exists() else "unknown"


def public_auth_identity(summary: dict | None) -> dict | None:
    if not summary or summary.get("error"):
        return None
    return {
        "email": summary.get("email"),
        "plan": summary.get("plan"),
        "organization": summary.get("organization"),
    }


def identities_match(left: dict | None, right: dict | None) -> bool:
    if not left or not right:
        return False
    if not left.get("email") or left.get("email") != right.get("email"):
        return False
    if left.get("plan") != right.get("plan"):
        return False
    left_org = left.get("organization")
    right_org = right.get("organization")
    if left_org and right_org and left_org != right_org:
        return False
    return True


def current_state_payload() -> dict:
    active = active_label()
    target = target_auth_path()
    target_digest = sha256_file(target)
    current_identity = public_auth_identity(read_codex_auth_summary(CODEX_HOME))
    matched_profiles: list[str] = []
    identity_matched_profiles: list[str] = []
    for profile_dir in profile_dirs():
        auth = profile_dir / AUTH_NAME
        profile_digest = sha256_file(auth)
        if target_digest and profile_digest and target_digest == profile_digest:
            matched_profiles.append(profile_dir.name)
            continue
        profile_identity = public_auth_identity(read_codex_auth_summary(profile_dir))
        if identities_match(current_identity, profile_identity):
            identity_matched_profiles.append(profile_dir.name)

    if matched_profiles:
        match_method = "hash"
        effective_matches = matched_profiles
    elif identity_matched_profiles:
        match_method = "identity"
        effective_matches = identity_matched_profiles
    else:
        match_method = None
        effective_matches = []

    matched_profile = effective_matches[0] if len(effective_matches) == 1 else None
    if active != "unknown":
        auth_match = "matched" if active in effective_matches else "mismatch"
    elif matched_profile:
        auth_match = "matched"
    else:
        auth_match = "unknown"

    matches = running_codex_processes()
    return {
        "ok": True,
        "active_label": active,
        "matched_profile": matched_profile,
        "matched_profiles": matched_profiles,
        "identity_matched_profiles": identity_matched_profiles,
        "match_method": match_method,
        "current_identity": current_identity,
        "auth_match": auth_match,
        "target_auth": file_summary_obj(target),
        "credentials_store": config_credentials_store() or "not set",
        "codex_running": None if matches is None else bool(matches),
        "process_check": "unknown" if matches is None else "ok",
    }

def config_credentials_store() -> str | None:
    config = CODEX_HOME / "config.toml"
    if not config.exists():
        return None
    try:
        for raw in config.read_text(encoding="utf-8", errors="replace").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("cli_auth_credentials_store"):
                _, value = line.split("=", 1)
                return value.strip().strip('"').strip("'").lower()
    except OSError:
        return None
    return None


def assert_auth_store_allowed() -> None:
    store = config_credentials_store()
    if store == "keyring":
        die('~/.codex/config.toml sets cli_auth_credentials_store = "keyring"; file switching is disabled', EXIT_KEYRING)
    if store and store not in {"file", "auto"}:
        die(f"unsupported cli_auth_credentials_store value: {store}", EXIT_KEYRING)


def windows_process_rows() -> list[dict] | None:
    script = """
$items = Get-CimInstance Win32_Process -ErrorAction SilentlyContinue |
  Select-Object ProcessId,Name,CommandLine
$items | ConvertTo-Json -Compress
"""
    try:
        result = subprocess.run(
            [windows_powershell_executable(), "-NoProfile", "-NonInteractive", "-Command", script],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=15,
        )
    except Exception:
        return None
    raw = result.stdout.strip()
    if not raw:
        return []
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError:
        return None
    if isinstance(parsed, dict):
        return [parsed]
    return parsed if isinstance(parsed, list) else None


def windows_codex_names_present() -> bool | None:
    """Cheap liveness probe by process name only (no command lines).

    Suitable for wait loops; the authoritative marker-based check still uses
    the full CIM dump. False positives just trigger one more full dump.
    """
    try:
        result = subprocess.run(
            ["tasklist", "/fo", "csv", "/nh"],
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=10,
        )
    except Exception:
        return None
    text = result.stdout.lower()
    return any(name.lower() in text for name in WINDOWS_CODEX_PROCESS_NAMES)


def is_windows_codex_process(name: str, command: str) -> bool:
    if any(marker in command for marker in IGNORED_CODEX_PROCESS_MARKERS):
        return False
    if name in WINDOWS_CODEX_PROCESS_NAMES:
        if name == "app-server.exe":
            return "codex" in command.lower()
        return True
    return any(marker in command for marker in WINDOWS_CODEX_PROCESS_MARKERS)


def running_codex_process_entries_windows() -> list[tuple[int, str]] | None:
    rows = windows_process_rows()
    if rows is None:
        return None
    current_pid = os.getpid()
    matches: list[tuple[int, str]] = []
    for row in rows:
        try:
            pid = int(row.get("ProcessId"))
        except (TypeError, ValueError):
            continue
        if pid == current_pid:
            continue
        name = str(row.get("Name") or "")
        command = str(row.get("CommandLine") or name)
        if is_windows_codex_process(name, command):
            matches.append((pid, concise_process_text(pid, name, command)))
    return matches


def running_codex_process_entries() -> list[tuple[int, str]] | None:
    if IS_WINDOWS:
        return running_codex_process_entries_windows()
    try:
        result = subprocess.run(
            ["ps", "-axo", "pid=,command="],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        return None
    current_pid = os.getpid()
    matches: list[tuple[int, str]] = []
    for line in result.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        pid_text, _, command = stripped.partition(" ")
        try:
            pid = int(pid_text)
        except ValueError:
            continue
        if pid == current_pid:
            continue
        if any(marker in command for marker in IGNORED_CODEX_PROCESS_MARKERS):
            continue
        if any(marker in command for marker in CODEX_PROCESS_MARKERS):
            matches.append((pid, stripped[:220]))
    return matches


def running_codex_processes() -> list[str] | None:
    entries = running_codex_process_entries()
    if entries is None:
        return None
    return [command for _pid, command in entries]


def stop_windows_processes(entries: list[tuple[int, str]], force: bool) -> list[str]:
    touched: list[str] = []
    for pid, command in entries:
        args = ["taskkill", "/PID", str(pid), "/T"]
        if force:
            args.append("/F")
        result = subprocess.run(
            args,
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        if result.returncode == 0:
            touched.append(command)
    return touched


def stop_codex_processes(grace_seconds: float) -> dict:
    entries = running_codex_process_entries()
    if entries is None:
        return {
            "ok": False,
            "error": "could not inspect running processes",
            "exit_code": EXIT_PROCESS_UNKNOWN,
            "process_check": "unknown",
        }
    if not entries:
        return {
            "ok": True,
            "terminated": [],
            "killed": [],
            "remaining": [],
            "process_check": "ok",
        }

    if IS_WINDOWS:
        terminated = stop_windows_processes(entries, force=False)
        deadline = time.time() + max(0.0, grace_seconds)
        # Wait with cheap name-only probes; the expensive PowerShell/CIM
        # command-line dump only runs to confirm, not every poll. The quick
        # probe cannot see marker-only matches, so "names gone" must be
        # verified by a full dump before ending the grace period early.
        while time.time() < deadline:
            if windows_codex_names_present() is False and not (running_codex_process_entries() or []):
                break
            time.sleep(0.5)
        remaining_entries = running_codex_process_entries() or []
        killed = stop_windows_processes(remaining_entries, force=True)
        final_entries = (running_codex_process_entries() or []) if remaining_entries else []
        return {
            "ok": not final_entries,
            "terminated": terminated,
            "killed": killed,
            "remaining": [command for _pid, command in final_entries],
            "process_check": "ok",
        }

    terminated: list[str] = []
    for pid, command in entries:
        try:
            os.kill(pid, signal.SIGTERM)
            terminated.append(command)
        except ProcessLookupError:
            terminated.append(command)
        except PermissionError:
            pass

    deadline = time.time() + max(0.0, grace_seconds)
    remaining_entries = running_codex_process_entries() or []
    while remaining_entries and time.time() < deadline:
        time.sleep(0.2)
        remaining_entries = running_codex_process_entries() or []

    killed: list[str] = []
    for pid, command in remaining_entries:
        try:
            os.kill(pid, signal.SIGKILL)
            killed.append(command)
        except ProcessLookupError:
            killed.append(command)
        except PermissionError:
            pass

    final_entries = running_codex_process_entries() or []
    return {
        "ok": not final_entries,
        "terminated": terminated,
        "killed": killed,
        "remaining": [command for _pid, command in final_entries],
        "process_check": "ok",
    }

def assert_codex_not_running() -> None:
    matches = running_codex_processes()
    if matches is None:
        die("could not inspect running processes; refusing to switch safely", EXIT_PROCESS_UNKNOWN)
    if not matches:
        return
    print("Codex-related processes are running; refusing to switch auth while app/session is active:")
    for match in matches[:10]:
        print(f"  {match}")
    if len(matches) > 10:
        print(f"  ... {len(matches) - 10} more")
    die("quit Codex Desktop and Codex app-server sessions, then retry", EXIT_CODEX_RUNNING)


def copy_auth(src: Path, dst: Path) -> None:
    dst.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
    os.chmod(dst.parent, 0o700)
    tmp = dst.with_name(f".{dst.name}.{os.getpid()}.tmp")
    try:
        shutil.copy2(src, tmp)
        os.chmod(tmp, 0o600)
        os.replace(tmp, dst)
    except BaseException:
        # Never strand a temp file holding credential bytes next to auth.json.
        unlink_silent(tmp)
        raise
    os.chmod(dst, 0o600)


def create_backup() -> Path | None:
    current = target_auth_path()
    if not current.exists():
        return None
    ensure_switch_dirs()
    backup_dir = create_backup_dir()
    backup_auth = backup_dir / AUTH_NAME
    shutil.copy2(current, backup_auth)
    os.chmod(backup_auth, 0o600)
    return backup_dir


def create_backup_dir() -> Path:
    ensure_switch_dirs()
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    backup_dir = BACKUP_ROOT / stamp
    suffix = 2
    while backup_dir.exists():
        backup_dir = BACKUP_ROOT / f"{stamp}-{suffix}"
        suffix += 1
    backup_dir.mkdir(mode=0o700)
    prune_backups(exclude=backup_dir)
    return backup_dir


def prune_backups(keep: int = BACKUP_KEEP, exclude: Path | None = None) -> None:
    """Backups accumulated forever; keep only the newest `keep` directories.

    `exclude` protects a just-created directory: name-sorted pruning could
    otherwise delete it after a backward wall-clock step.
    """
    if not BACKUP_ROOT.exists():
        return
    try:
        dirs = sorted(p for p in BACKUP_ROOT.iterdir() if p.is_dir() and p != exclude)
    except OSError:
        return
    for stale in dirs[:-keep]:
        shutil.rmtree(stale, ignore_errors=True)


def backup_file(src: Path, name: str) -> Path | None:
    if not src.exists():
        return None
    backup_dir = create_backup_dir()
    backup_path = backup_dir / name
    shutil.copy2(src, backup_path)
    os.chmod(backup_path, 0o600)
    return backup_path


def decode_jwt_payload(token: str | None) -> dict | None:
    if not token:
        return None
    parts = token.split(".")
    if len(parts) < 2:
        return None
    payload = parts[1]
    payload += "=" * (-len(payload) % 4)
    try:
        return json.loads(base64.urlsafe_b64decode(payload.encode("ascii")).decode("utf-8"))
    except Exception:
        return None


def read_codex_auth_summary(home_path: Path) -> dict | None:
    auth_path = home_path / AUTH_NAME
    if not auth_path.exists() or not auth_path.is_file():
        return None
    try:
        if has_overly_open_posix_permissions(auth_path):
            return {"error": "auth.json permissions are too open"}
        parsed = json.loads(auth_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {"error": "auth.json is unreadable"}
    tokens = parsed.get("tokens") if isinstance(parsed, dict) else None
    if not isinstance(tokens, dict):
        return {"error": "auth.json is missing tokens"}
    jwt_payload = decode_jwt_payload(tokens.get("id_token"))
    auth_details = jwt_payload.get("https://api.openai.com/auth") if isinstance(jwt_payload, dict) else None
    auth_object = auth_details if isinstance(auth_details, dict) else {}
    organizations = auth_object.get("organizations") if isinstance(auth_object, dict) else []
    default_org = None
    if isinstance(organizations, list):
        default_org = next((org for org in organizations if isinstance(org, dict) and org.get("is_default")), None)
        if default_org is None:
            default_org = next((org for org in organizations if isinstance(org, dict)), None)
    return {
        "email": jwt_payload.get("email") if isinstance(jwt_payload, dict) else None,
        "plan": auth_object.get("chatgpt_plan_type") if isinstance(auth_object, dict) else None,
        "organization": default_org.get("title") if isinstance(default_org, dict) else None,
        "account_id": tokens.get("account_id"),
        "access_token": tokens.get("access_token"),
        "last_refresh": parsed.get("last_refresh") if isinstance(parsed, dict) else None,
    }


def normalize_usage_window(raw: dict | None) -> dict | None:
    if not isinstance(raw, dict):
        return None
    used = raw.get("used_percent", raw.get("usedPercent", 0))
    try:
        used_percent = max(0.0, min(100.0, float(used)))
    except (TypeError, ValueError):
        used_percent = 0.0
    reset_after = raw.get("reset_after_seconds", raw.get("resetAfterSeconds"))
    reset_at = None
    if isinstance(reset_after, (int, float)) and reset_after > 0:
        reset_at = (datetime.now(timezone.utc) + timedelta(seconds=float(reset_after))).isoformat()
    return {
        "used_percent": used_percent,
        "remaining_percent": max(0.0, 100.0 - used_percent),
        "reset_after_seconds": reset_after if isinstance(reset_after, (int, float)) else None,
        "reset_at": reset_at,
    }


def rounded_percent(value: float | None) -> int | None:
    if value is None:
        return None
    return int(round(value))


def usage_row_base(profile: str) -> dict:
    return {
        "profile": profile,
        "account": "unknown",
        "plan": None,
        "five_hour_left": None,
        "five_hour_reset": None,
        "weekly_left": None,
        "weekly_reset": None,
        "fetched_at": datetime.now(timezone.utc).isoformat(),
        "error": None,
    }


def collect_usage_rows(dirs: list[Path]) -> list[dict]:
    """Fetch usage for all profiles concurrently under one wall-clock budget.

    The old sequential loop could exceed the frontends' kill budget with 3+
    profiles, losing even the rows that had already been fetched.
    """
    if not dirs:
        return []
    pool = ThreadPoolExecutor(max_workers=min(4, len(dirs)))
    try:
        futures = [(profile_dir, pool.submit(codex_usage_row, profile_dir)) for profile_dir in dirs]
        deadline = time.time() + CODEX_USAGE_TOTAL_BUDGET_SECONDS
        rows: list[dict] = []
        for profile_dir, future in futures:
            try:
                # No floor: once the deadline passes, remaining futures time out
                # immediately instead of stacking 0.5s each.
                rows.append(future.result(timeout=max(0.0, deadline - time.time())))
            except FuturesTimeoutError:
                row = usage_row_base(profile_dir.name)
                row["error"] = f"Profile {profile_dir.name} usage request timed out."
                rows.append(row)
            except Exception as error:
                row = usage_row_base(profile_dir.name)
                row["error"] = f"Profile {profile_dir.name} usage request failed: {error}"
                rows.append(row)
        return rows
    finally:
        pool.shutdown(wait=False, cancel_futures=True)


def codex_usage_row(profile_dir: Path) -> dict:
    profile = profile_dir.name
    auth = read_codex_auth_summary(profile_dir)
    row = usage_row_base(profile)
    if not auth:
        row["error"] = f"Profile {profile} is missing auth tokens. Run `codex-desktop-switch login {profile}`."
        return row
    if auth.get("error"):
        row["error"] = f"Profile {profile} {auth['error']}."
        return row
    row["account"] = auth.get("email") or "unknown"
    row["plan"] = auth.get("plan")
    access_token = auth.get("access_token")
    account_id = auth.get("account_id")
    if not access_token or not account_id:
        row["error"] = f"Profile {profile} is missing auth tokens. Run `codex-desktop-switch login {profile}`."
        return row
    request = urllib.request.Request(
        CODEX_USAGE_URL,
        headers={
            "Authorization": f"Bearer {access_token}",
            "ChatGPT-Account-Id": account_id,
            "User-Agent": CODEX_USAGE_USER_AGENT,
        },
        method="GET",
    )
    try:
        with urllib.request.urlopen(request, timeout=CODEX_USAGE_TIMEOUT_SECONDS) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        if error.code == 401:
            row["error"] = f"Profile {profile} token expired. Re-login with `codex-desktop-switch login {profile}`."
        else:
            row["error"] = f"Profile {profile} usage request failed with {error.code}."
        return row
    except Exception as error:
        row["error"] = f"Profile {profile} usage request failed: {error}"
        return row
    rate_limit = payload.get("rate_limit", payload.get("rateLimit", {}))
    primary = normalize_usage_window(rate_limit.get("primary_window", rate_limit.get("primaryWindow")) if isinstance(rate_limit, dict) else None)
    secondary = normalize_usage_window(rate_limit.get("secondary_window", rate_limit.get("secondaryWindow")) if isinstance(rate_limit, dict) else None)
    row["account"] = payload.get("email") or row["account"]
    row["plan"] = payload.get("plan_type", payload.get("planType", row["plan"]))
    row["five_hour_left"] = rounded_percent(primary.get("remaining_percent") if primary else None)
    row["five_hour_reset"] = primary.get("reset_at") if primary else None
    row["weekly_left"] = rounded_percent(secondary.get("remaining_percent") if secondary else None)
    row["weekly_reset"] = secondary.get("reset_at") if secondary else None
    row["fetched_at"] = datetime.now(timezone.utc).isoformat()
    return row


