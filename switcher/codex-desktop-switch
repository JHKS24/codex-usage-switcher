def die(message: str, code: int = EXIT_OTHER) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def emit_json(payload: dict) -> None:
    print(json.dumps(payload, ensure_ascii=False, separators=(",", ":")))


def json_error(message: str, code: int, **extra: object) -> None:
    payload = dict(extra)
    payload.update({"ok": False, "error": message, "exit_code": code})
    emit_json(payload)
    raise SystemExit(code)


def ensure_switch_dirs() -> None:
    SWITCH_HOME.mkdir(mode=0o700, exist_ok=True)
    BACKUP_ROOT.mkdir(mode=0o700, exist_ok=True)
    PROFILES_ROOT.mkdir(mode=0o700, exist_ok=True)
    os.chmod(SWITCH_HOME, 0o700)
    os.chmod(BACKUP_ROOT, 0o700)
    os.chmod(PROFILES_ROOT, 0o700)


def write_private_json(path: Path, payload: dict) -> None:
    ensure_switch_dirs()
    tmp = path.with_suffix(path.suffix + ".tmp")
    try:
        tmp.write_text(json.dumps(payload, ensure_ascii=False, separators=(",", ":")), encoding="utf-8")
        os.chmod(tmp, 0o600)
        tmp.replace(path)
    except BaseException:
        unlink_silent(tmp)
        raise
    os.chmod(path, 0o600)


def has_overly_open_posix_permissions(path: Path) -> bool:
    if IS_WINDOWS:
        return False
    mode = stat.S_IMODE(path.stat().st_mode)
    return bool(mode & 0o077)


def read_private_json(path: Path) -> dict | None:
    try:
        if has_overly_open_posix_permissions(path):
            return None
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def unlink_silent(path: Path) -> None:
    try:
        path.unlink()
    except OSError:
        pass


def resolve_codex_cli_path() -> Path | None:
    override = os.environ.get("CODEX_CLI_PATH")
    if override:
        return Path(override)
    codex_in_path = shutil.which("codex")
    if codex_in_path:
        return Path(codex_in_path)
    if IS_MACOS:
        app_codex = Path("/Applications/Codex.app/Contents/Resources/codex")
        if app_codex.exists():
            return app_codex
    return None


def resolve_codex_app_path() -> Path | None:
    override = os.environ.get("CODEX_DESKTOP_APP_PATH")
    if override:
        return Path(override)
    if IS_MACOS:
        app = Path("/Applications/Codex.app")
        return app if app.exists() else None
    if IS_WINDOWS:
        candidates: list[Path] = []
        for env_name in ("LOCALAPPDATA", "ProgramFiles", "ProgramFiles(x86)"):
            root = os.environ.get(env_name)
            if root:
                candidates.extend([
                    Path(root) / "Programs" / "Codex" / "Codex.exe",
                    Path(root) / "Codex" / "Codex.exe",
                ])
        path_hit = shutil.which("Codex.exe")
        if path_hit:
            candidates.append(Path(path_hit))
        return next((path for path in candidates if path.exists()), None)
    return None


def open_url(url: str) -> bool:
