def claude_load_credentials() -> dict | None:
    raw = None
    source = "unknown"
    if CLAUDE_USAGE_BAR_CREDENTIALS.exists():
        try:
            if has_overly_open_posix_permissions(CLAUDE_USAGE_BAR_CREDENTIALS):
                return None
            raw = CLAUDE_USAGE_BAR_CREDENTIALS.read_text(encoding="utf-8")
            source = "claude_usage_bar"
        except OSError:
            raw = None
    if not raw:
        raw = keychain_read(CLAUDE_SERVICE, CLAUDE_ACCOUNT)
        source = "keychain"
    if not raw:
        return None
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return None
    if not isinstance(data, dict):
        return None
    if "accessToken" in data or "refreshToken" in data or "expiresAt" in data:
        data = {
            "access_token": data.get("accessToken"),
            "refresh_token": data.get("refreshToken"),
            "expires_at": parse_claude_expires_at(data.get("expiresAt")),
            "scopes": data.get("scopes") or CLAUDE_SCOPES,
            "credential_source": source,
        }
    else:
        data["credential_source"] = source
    if not data.get("access_token"):
        return None
    return data


def parse_claude_expires_at(value: object) -> int | None:
    if isinstance(value, (int, float)):
        return int(value)
    if not isinstance(value, str) or not value:
        return None
    normalized = value.replace("Z", "+00:00")
    try:
        return int(datetime.fromisoformat(normalized).timestamp())
    except ValueError:
        return None


def claude_save_credentials(data: dict) -> None:
    expires_at = data.get("expires_at")
    if isinstance(expires_at, (int, float)):
        expires_at_value = datetime.fromtimestamp(expires_at, timezone.utc).isoformat().replace("+00:00", "Z")
    else:
        expires_at_value = expires_at
    safe = {
        "accessToken": data.get("access_token"),
        "refreshToken": data.get("refresh_token"),
        "expiresAt": expires_at_value,
        "scopes": data.get("scopes") or CLAUDE_SCOPES,
    }
    CLAUDE_USAGE_BAR_CREDENTIALS.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
    os.chmod(CLAUDE_USAGE_BAR_CREDENTIALS.parent, 0o700)
    tmp = CLAUDE_USAGE_BAR_CREDENTIALS.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(safe, ensure_ascii=False, separators=(",", ":")), encoding="utf-8")
    os.chmod(tmp, 0o600)
    tmp.replace(CLAUDE_USAGE_BAR_CREDENTIALS)
    os.chmod(CLAUDE_USAGE_BAR_CREDENTIALS, 0o600)


def claude_credentials_from_token_response(data: dict, fallback: dict | None = None) -> dict:
    expires_in = data.get("expires_in")
    expires_at = None
    if isinstance(expires_in, (int, float)):
        expires_at = claude_now() + int(expires_in)
    elif isinstance(expires_in, str) and expires_in.isdigit():
        expires_at = claude_now() + int(expires_in)
    elif fallback:
        expires_at = fallback.get("expires_at")
    scope_value = data.get("scope")
    scopes = scope_value.split() if isinstance(scope_value, str) and scope_value else (fallback or {}).get("scopes") or CLAUDE_SCOPES
    return {
        "access_token": data.get("access_token"),
        "refresh_token": data.get("refresh_token") or (fallback or {}).get("refresh_token"),
        "expires_at": expires_at,
        "scopes": scopes,
    }


def claude_cooldown_remaining() -> int:
    payload = read_private_json(CLAUDE_COOLDOWN_FILE)
    if not payload:
        return 0
    until = payload.get("until")
    if not isinstance(until, (int, float)):
        unlink_silent(CLAUDE_COOLDOWN_FILE)
        return 0
    remaining = int(until - claude_now())
    if remaining <= 0:
        unlink_silent(CLAUDE_COOLDOWN_FILE)
        return 0
    return remaining


def claude_set_cooldown(reason: str = "rate_limited") -> None:
    write_private_json(CLAUDE_COOLDOWN_FILE, {
        "reason": reason,
        "until": claude_now() + CLAUDE_RATE_LIMIT_COOLDOWN_SECONDS,
    })


def claude_refuse_if_cooling_down(json_mode: bool = False) -> None:
    remaining = claude_cooldown_remaining()
    if remaining <= 0:
        return
    message = f"Claude OAuth is rate limited; retry after about {max(1, (remaining + 59) // 60)} minutes."
    if json_mode:
        json_error(message, EXIT_CLAUDE_USAGE, retry_after_seconds=remaining, error="rate_limited")
    die(message, EXIT_CLAUDE_USAGE)


def claude_token_exchange_error(detail: str) -> tuple[str, bool]:
    lowered = detail.lower()
    if "http 429" in lowered or "rate_limit" in lowered or "rate limited" in lowered:
        return (
            "Claude OAuth token exchange failed: token endpoint rate limited. "
            "Do not retry the same code; run claude-login-reset, wait if needed, then start a fresh browser login.",
            True,
        )
    if (
        "invalid_grant" in lowered
        or "expired code" in lowered
        or "code expired" in lowered
        or ("authorization code" in lowered and "expired" in lowered)
    ):
        return (
            "Claude OAuth token exchange failed: stale or expired OAuth code. "
            "Start a fresh Claude login and paste the new code only once.",
            False,
        )
    if "invalid_request" in lowered or "redirect_uri" in lowered:
        return (
            "Claude OAuth token exchange failed: token request rejected. "
            "Check endpoint, redirect_uri, and pending login state.",
            False,
        )
    if "invalid json" in lowered or "parse" in lowered:
        return "Claude OAuth token exchange failed: token response parse failure.", False
    return f"Claude OAuth token exchange failed: {detail}", False


def claude_post_json(url: str, body: dict) -> dict:
    request_body = json.dumps(body).encode("utf-8")
    helper = CLAUDE_OAUTH_POST_HELPER
    if helper.exists() and os.access(helper, os.X_OK):
        result = subprocess.run(
            [str(helper), url],
            input=request_body,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        body_text = result.stdout.decode("utf-8", errors="replace")
        if result.returncode:
            detail = result.stderr.decode("utf-8", errors="replace").strip() or body_text.strip()
            raise RuntimeError(f"Claude API request failed: {detail[:400] or 'urlsession helper failed'}")
        try:
            return json.loads(body_text)
        except json.JSONDecodeError as error:
            raise RuntimeError(f"Claude API returned invalid JSON: {error}") from error

    curl = shutil.which("curl") or "/usr/bin/curl"
    try:
        result = subprocess.run(
            [
                curl,
                "-sS",
                "--connect-timeout",
                "5",
                "--max-time",
                "15",
                "-X",
                "POST",
                "-H",
                "Content-Type: application/json",
                "-H",
                f"User-Agent: {CLAUDE_USAGE_BAR_USER_AGENT}",
                "--data-binary",
                "@-",
                "-w",
                "\n%{http_code}",
                url,
            ],
            input=request_body,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
    except FileNotFoundError as error:
        raise RuntimeError("curl not found; install curl or ship the claude-oauth-post helper") from error
    if result.returncode:
        detail = result.stderr.decode("utf-8", errors="replace")[:400]
        raise RuntimeError(f"Claude API request failed: {detail or 'curl failed'}")
    output = result.stdout.decode("utf-8", errors="replace")
    body_text, _, status_text = output.rpartition("\n")
    try:
        status = int(status_text.strip())
    except ValueError:
        raise RuntimeError("Claude API returned an invalid HTTP status")
    if status < 200 or status >= 300:
        raise RuntimeError(f"Claude API HTTP {status}: {body_text[:400]}")
    try:
        return json.loads(body_text)
    except json.JSONDecodeError as error:
        raise RuntimeError(f"Claude API returned invalid JSON: {error}") from error


def claude_get_authorized(url: str, access_token: str) -> dict:
    request = urllib.request.Request(
        url,
        headers={"Authorization": f"Bearer {access_token}", "anthropic-beta": "oauth-2025-04-20"},
        method="GET",
    )
    try:
        # Keep token-refresh (15s) plus this request under the frontends' 35s
        # kill budget; the old 30s+30s stack could never finish in time.
        with urllib.request.urlopen(request, timeout=15) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        detail = error.read().decode("utf-8", errors="replace")[:400]
        raise RuntimeError(f"Claude usage HTTP {error.code}: {detail}") from error
    except Exception as error:
        raise RuntimeError(f"Claude usage request failed: {error}") from error


def claude_refresh_credentials(credentials: dict) -> dict | None:
    refresh_token = credentials.get("refresh_token")
    if not refresh_token:
        return None
    body = {
        "grant_type": "refresh_token",
        "refresh_token": refresh_token,
        "client_id": CLAUDE_CLIENT_ID,
    }
    scopes = credentials.get("scopes")
    if isinstance(scopes, list) and scopes:
        body["scope"] = " ".join(str(scope) for scope in scopes)
    refreshed = claude_post_json(CLAUDE_TOKEN_ENDPOINT, body)
    updated = claude_credentials_from_token_response(refreshed, fallback=credentials)
    if not updated.get("access_token"):
        return None
    claude_save_credentials(updated)
    return updated


def claude_valid_credentials() -> dict | None:
    credentials = claude_load_credentials()
    if not credentials:
        return None
    expires_at = credentials.get("expires_at")
    if isinstance(expires_at, (int, float)) and expires_at <= claude_now() + 120:
        return claude_refresh_credentials(credentials)
    return credentials


def claude_bucket(raw: dict, key: str) -> dict | None:
    value = raw.get(key)
    if not isinstance(value, dict):
        return None
    return {
        "utilization": value.get("utilization"),
        "resets_at": value.get("resets_at"),
    }


def claude_code_looks_valid(raw_code: str) -> bool:
    value = raw_code.strip()
    if not value or len(value) < 20:
        return False
    lowered = value.lower()
    if "codex-desktop-switch" in lowered or "claude-login" in lowered:
        return False
    if value.startswith("/") or value.startswith("~"):
        return False
    if any(ch.isspace() for ch in value):
        return False
    return True


def parse_claude_oauth_input(raw_code: str) -> tuple[str, str | None]:
    value = raw_code.strip()
    if not claude_code_looks_valid(value):
        die("paste only the Claude OAuth code shown in the browser, not `codex-desktop-switch claude-login`", EXIT_CLAUDE_USAGE)
    if value.startswith("https://") or value.startswith("http://"):
        parsed = urllib.parse.urlparse(value)
        query = urllib.parse.parse_qs(parsed.query)
        code_values = query.get("code") or []
        state_values = query.get("state") or []
        if code_values:
            return code_values[0].strip(), state_values[0].strip() if state_values else None
    parts = value.split("#", 1)
    return parts[0].strip(), parts[1].strip() if len(parts) > 1 else None


def claude_auth_flow_payload() -> dict:
    verifier = b64url(secrets.token_bytes(32))
    challenge = b64url(hashlib.sha256(verifier.encode("ascii")).digest())
    state = b64url(secrets.token_bytes(32))
    params = {
        "code": "true",
        "client_id": CLAUDE_CLIENT_ID,
        "response_type": "code",
        "redirect_uri": CLAUDE_REDIRECT_URI,
        "scope": " ".join(CLAUDE_SCOPES),
        "code_challenge": challenge,
        "code_challenge_method": "S256",
        "state": state,
    }
    auth_url = CLAUDE_AUTHORIZE_ENDPOINT + "?" + urllib.parse.urlencode(params)
    return {
        "verifier": verifier,
        "state": state,
        "auth_url": auth_url,
        "created_at": claude_now(),
    }


def claude_open_auth_flow() -> dict:
    claude_refuse_if_cooling_down()
    payload = claude_auth_flow_payload()
    write_private_json(CLAUDE_PENDING_FILE, payload)
    open_url(payload["auth_url"])
    return payload


def claude_finish_auth_flow(raw_code: str, pending: dict | None = None) -> dict:
    pending = pending or read_private_json(CLAUDE_PENDING_FILE)
    if not pending:
        die("no pending Claude OAuth login; start with claude-login-start", EXIT_CLAUDE_USAGE)
    created_at = pending.get("created_at")
    if isinstance(created_at, (int, float)) and created_at < claude_now() - 15 * 60:
        unlink_silent(CLAUDE_PENDING_FILE)
        die("Claude OAuth login expired; start again", EXIT_CLAUDE_USAGE)
    code, returned_state = parse_claude_oauth_input(raw_code)
    expected_state = str(pending.get("state") or "")
    if returned_state and returned_state != expected_state:
        unlink_silent(CLAUDE_PENDING_FILE)
        die("Claude OAuth state mismatch; reset stale pending login and start again", EXIT_CLAUDE_USAGE)
    if not code:
        die("missing Claude OAuth code", EXIT_CLAUDE_USAGE)
    verifier = str(pending.get("verifier") or "")
    if not verifier:
        die("missing Claude OAuth verifier; start again", EXIT_CLAUDE_USAGE)
    try:
        token_response = claude_post_json(CLAUDE_TOKEN_ENDPOINT, {
            "grant_type": "authorization_code",
            "code": code,
            "state": expected_state,
            "client_id": CLAUDE_CLIENT_ID,
            "redirect_uri": CLAUDE_REDIRECT_URI,
            "code_verifier": verifier,
        })
    except RuntimeError as error:
        detail = str(error)
        # A failed token exchange often leaves a one-time OAuth code unusable.
        # Force the next attempt to start a fresh browser flow instead of
        # accidentally retrying stale pending state.
        unlink_silent(CLAUDE_PENDING_FILE)
        message, should_cooldown = claude_token_exchange_error(detail)
        if should_cooldown:
            claude_set_cooldown()
        die(message, EXIT_CLAUDE_USAGE)
    credentials = claude_credentials_from_token_response(token_response)
    if not credentials.get("access_token"):
        die("Claude OAuth token response did not include an access token", EXIT_CLAUDE_USAGE)
    try:
        claude_save_credentials(credentials)
    except Exception as error:
        die(f"Claude OAuth credential save failed: {error}", EXIT_CLAUDE_USAGE)
    unlink_silent(CLAUDE_PENDING_FILE)
    return {
        "ok": True,
        "authenticated": True,
        "storage": str(CLAUDE_USAGE_BAR_CREDENTIALS),
    }


def command_claude_login_start(args: argparse.Namespace) -> None:
    claude_refuse_if_cooling_down(json_mode=getattr(args, "json", False))
    claude_open_auth_flow()
    payload = {
        "ok": True,
        "action": "open_browser",
        "pending": str(CLAUDE_PENDING_FILE),
    }
    if getattr(args, "json", False):
        emit_json(payload)
        return
    print("action\topen Claude browser login")
    print("next\tpaste code into Claude login prompt")


def command_claude_login_finish(args: argparse.Namespace) -> None:
    raw_code = sys.stdin.read().strip() if getattr(args, "code_stdin", False) else (args.code or "").strip()
    result = claude_finish_auth_flow(raw_code)
    if getattr(args, "json", False):
        emit_json(result)
        return
    print("authenticated\tClaude")
    print(f"storage\t{CLAUDE_USAGE_BAR_CREDENTIALS}")


def command_claude_login(_args: argparse.Namespace) -> None:
    claude_refuse_if_cooling_down()
